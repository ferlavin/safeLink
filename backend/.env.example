# Conexion a PostgreSQL (local via docker-compose por defecto)
DATABASE_URL=postgresql+psycopg2://postgres:TU_PASSWORD@localhost:5432/SafeLink

# Seguridad JWT (cambiar JWT_SECRET en produccion)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Origen(es) permitidos para CORS. Separar por comas si hay varios.
# Producción: tu dominio Vercel, ej. https://safelink.vercel.app
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174,https://safelink.vercel.app

# Usuario administrador inicial (se crea automaticamente al arrancar)
ADMIN_EMAIL=admin@safelink.app
ADMIN_PASSWORD=admin1234
