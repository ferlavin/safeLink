{
  "manifest_version": 3,
  "name": "SafeLink",
  "version": "1.0.0",
  "description": "Te avisa con colores si un enlace es seguro antes de hacer clic.",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://www.google.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.google.com/search*",
        "*://google.com/search*",
        "*://www.google.com.ar/search*",
        "*://www.google.com.mx/search*",
        "*://www.google.es/search*",
        "*://www.google.co.uk/search*",
        "*://www.google.it/search*",
        "*://www.google.de/search*",
        "*://www.google.fr/search*"
      ],
      "js": ["content/inject.js"],
      "css": ["content/inject.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:5173/*", "http://localhost:5174/*", "http://127.0.0.1:5173/*"],
      "js": ["content/site-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "SafeLink — Analizando...",
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
