      "html": "\n<body class=\"bg-[#100C08] text-white font-['Plus_Jakarta_Sans'] overflow-x-hidden\">\n    <style data-kid=\"0\">\n        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=IBM+Plex+Sans:wght@400;500;600&display=swap');\n\n        :root {\n            --ocean-twilight: #324AB2;\n            --neon-ice: #15F4EE;\n            --hot-fuchsia: #FF004F;\n            --pitch-black: #100C08;\n        }\n\n        .glass-panel {\n            background: rgba(255, 255, 255, 0.03);\n            backdrop-filter: blur(24px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);\n        }\n\n        .glass-panel-heavy {\n            background: rgba(255, 255, 255, 0.06);\n            backdrop-filter: blur(40px);\n            border: 1px solid rgba(255, 255, 255, 0.12);\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0) rotate(0deg); }\n            50% { transform: translateY(-20px) rotate(1deg); }\n        }\n\n        @keyframes float-slow {\n            0%, 100% { transform: translateY(0) rotate(0deg); }\n            50% { transform: translateY(-30px) rotate(-2deg); }\n        }\n\n        @keyframes pulse-glow {\n            0%, 100% { opacity: 0.3; filter: blur(100px); }\n            50% { opacity: 0.5; filter: blur(140px); }\n        }\n\n        .animate-float { animation: float 6s ease-in-out infinite; }\n        .animate-float-slow { animation: float-slow 8s ease-in-out infinite; }\n        .animate-pulse-glow { animation: pulse-glow 10s ease-in-out infinite; }\n\n        .text-gradient-aurora {\n            background: linear-gradient(to right, var(--neon-ice), #4facfe, var(--ocean-twilight));\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        .glow-fuchsia {\n            box-shadow: 0 0 15px var(--hot-fuchsia), 0 0 30px var(--hot-fuchsia);\n        }\n\n        .bg-noise {\n            background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n        }\n    </style>\n\n    \n    <nav class=\"fixed top-0 left-0 right-0 z-[100] px-8 py-6\" data-kid=\"1\">\n        <div class=\"max-w-7xl mx-auto flex items-center justify-between glass-panel px-8 py-4 rounded-full border border-white/10\" data-kid=\"2\">\n            <div class=\"flex items-center gap-2\" data-kid=\"3\">\n                <div class=\"w-8 h-8 bg-gradient-to-tr from-[var(--neon-ice)] to-[var(--ocean-twilight)] rounded-lg flex items-center justify-center\" data-kid=\"4\">\n                    <i class=\"ph ph-shield-check-fill text-black text-xl\" data-kid=\"5\"></i>\n                </div>\n                <span class=\"text-xl font-extrabold tracking-tight\" data-kid=\"6\">SafeLink</span>\n            </div>\n            <div class=\"hidden md:flex items-center gap-10 text-sm font-medium text-white/60\" data-kid=\"7\">\n                <a href=\"#\" class=\"hover:text-[var(--neon-ice)] transition\" data-kid=\"8\">Protection</a>\n                <a href=\"#\" class=\"hover:text-[var(--neon-ice)] transition\" data-kid=\"9\">Heuristics</a>\n                <a href=\"#\" class=\"hover:text-[var(--neon-ice)] transition\" data-kid=\"10\">Network</a>\n                <a href=\"#\" class=\"hover:text-[var(--neon-ice)] transition\" data-kid=\"11\">Enterprise</a>\n            </div>\n            <button class=\"bg-white text-black text-sm font-bold px-6 py-2.5 rounded-full hover:bg-[var(--neon-ice)] transition duration-300\" data-kid=\"12\">\n                Install Extension\n            </button>\n        </div>\n    </nav>\n\n    \n    <section class=\"relative min-h-[92