sparent pointer-events-none\" data-kid=\"93\"></div>\n        \n        <div class=\"max-w-7xl mx-auto relative z-10\" data-kid=\"94\">\n            <div class=\"flex flex-col md:flex-row md:items-end justify-between mb-24 gap-8\" data-kid=\"95\">\n                <div class=\"max-w-2xl\" data-kid=\"96\">\n                    <h2 class=\"text-5xl font-serif mb-6 leading-tight\" data-kid=\"97\">Deep Inspection Protocol</h2>\n                    <p class=\"text-[#F8F8FF]/60 text-lg\" data-kid=\"98\">Our four-stage verification process ensures that zero compromises are made on either organizational speed or endpoint safety.</p>\n                </div>\n                <div class=\"flex items-center gap-4\" data-kid=\"99\">\n                    <div class=\"px-6 py-3 border border-white/10 rounded-sm text-sm font-bold hover:bg-white/5 transition-all cursor-pointer\" data-kid=\"100\">Explore API</div>\n                </div>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-4 gap-4 md:gap-0 items-center\" data-kid=\"101\">\n                \n                <div class=\"relative group\" data-kid=\"102\">\n                    <div class=\"flex flex-col items-start p-8 md:pr-12 group-hover:translate-y-[-8px] transition-all duration-500\" data-kid=\"103\">\n                        <div class=\"w-16 h-16 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center mb-8 group-hover:bg-[#E60026] group-hover:border-[#E60026] group-hover:shadow-[0_0_30px_rgba(230,0,38,0.3)] transition-all\" data-kid=\"104\">\n                            <i class=\"ti ti-link text-2xl\" data-kid=\"105\"></i>\n                        </div>\n                        <h3 class=\"text-xl font-bold mb-3\" data-kid=\"106\">URL Interception</h3>\n                        <p class=\"text-sm text-white/40 leading-relaxed\" data-kid=\"107\">Incoming links are captured at the browser or gateway level before execution.</p>\n                    </div>\n                    \n                    <div class=\"hidden md:block absolute top-16 -right-4 z-20\" data-kid=\"108\">\n                        <div class=\"flex items-center\" data-kid=\"109\">\n                            <div class=\"w-8 h-[1px] bg-white/20\" data-kid=\"110\"></div>\n                            <div class=\"w-0 h-0 border-t-[4px] border-t-transparent border-b-[4px] border-b-transparent border-l-[6px] border-l-white/20\" data-kid=\"111\"></div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"relative group\" data-kid=\"112\">\n                    <div class=\"flex flex-col items-start p-8 md:px-12 group-hover:translate-y-[-8px] transition-all duration-500\" data-kid=\"113\">\n                        <div class=\"w-16 h-16 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center mb-8 group-hover:bg-[#E60026] group-hover:border-[#E60026] group-hover:shadow-[0_0_30px_rgba(230,0,38,0.3)] transition-all\" data-kid=\"114\">\n                            <i class=\"ti ti-search text-2xl\" data-kid=\"115\"></i>\n                        </div>\n                        <h3 class=\"text-xl font-bold mb-3\" data-kid=\"116\">DNS Validation</h3>\n                        <p class=\"text-sm text-white/40 leading-relaxed\" data-kid=\"117\">Instant cross-referencing against our global threat intelligence cloud.</p>\n                    </div>\n                    \n                    <div class=\"hidden md:block absolute top-16 -right-4 z-20\" data-kid=\"118\">\n                        <div class=\"flex items-center\" data-kid=\"119\">\n                            <div class=\"w-8 h-[1px] bg-white/20\" data-kid=\"120\"></div>\n                            <div class=\"w-0 h-0 border-t-[4px] border-t-transparent border-b-[4px] border-b-transparent border-l-[6px] border-l-white/20\" data-kid=\"121\"></div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"relative group\" data-kid=\"122\">\n                    <div class=\"flex flex-col items-start p-8 md:px-12 group-hover:translate-y-[-8px] transition-all duration-500\" data-kid=\"123\">\n                        <div class=\"w-16 h-16 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center mb-8 group-hover:bg-[#E60026] group-hover:border-[#E60026] group-hover:shadow-[0_0_30px_rgba(230,0,38,0.3)] transition-all\" data-kid=\"124\">\n                            <i class=\"ti ti-box-padding text-2xl\" data-kid=\"125\"></i>\n                        </div>\n                        <h3 class=\"text-xl font-bold mb-3\" data-kid=\"126\">JS Sandboxing</h3>\n                        <p class=\"text-sm text-white/40 leading-relaxed\" data-kid=\"127\">Execution of scripts in a remote, isolated environment to observe behavior.</p>\n                    </div>\n                    \n                    <div class=\"hidden md:block absolute top-16 -right-4 z-20\" data-kid=\"128\">\n                        <div class=\"flex items-center\" data-kid=\"129\">\n                            <div class=\"w-8 h-[1px] bg-white/20\" data-kid=\"130\"></div>\n                            <div class=\"w-0 h-0 border-t-[4px] border-t-transparent border-b-[4px] border-b-transparent border-l-[6px] border-l-white/20\" data-kid=\"131\"></div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"relative group\" data-kid=\"132\">\n                    <div class=\"flex flex-col items-start p-8 md:pl-12 group-hover:translate-y-[-8px] transition-all duration-500\" data-kid=\"133\">\n                        <div class=\"w-16 h-16 bg-[#E60026] rounded-xl flex items-center justify-center mb-8 shadow-[0_0_40px_rgba(230,0,38,0.4)]\" data-kid=\"134\">\n                            <i class=\"ti ti-shield-check text-2xl\" data-kid=\"135\"></i>\n                        </div>\n                        <h3 class=\"text-xl font-bold mb-3\" data-kid=\"136\">Verdict Delivery</h3>\n                        <p class=\"text-sm text-white/40 leading-relaxed\" data-kid=\"137\">Safe traffic is cleared, threats are blocked and logged for forensic analysis.</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-8\" data-kid=\"138\">\n        <div class=\"max-w-6xl mx-auto\" data-kid=\"139\">\n            <div class=\"text-center mb-20\" data-kid=\"140\">\n                <div class=\"text-[#E60026] font-bold text-xs uppercase tracking-[0.3em] mb-4\" data-kid=\"141\">Enterprise Grade Comparison</div>\n                <h2 class=\"text-5xl font-serif text-[#011F5B]\" data-kid=\"142\">SafeLink vs standard AV</h2>\n                <p class=\"mt-6 text-lg text-[#011F5B]/60 max-w-2xl mx-auto\" data-kid=\"143\">Legacy solutions focus on files. SafeLink secures the entire modern web browsing experience.</p>\n            </div>\n\n            <div class=\"overflow-hidden border border-[#011F5B]/10 rounded-sm bg-white shadow-[0_20px_40px_rgba(1,31,91,0.05)]\" data-kid=\"144\">\n                <table class=\"w-full text-left border-collapse\" data-kid=\"145\">\n                    <thead data-kid=\"146\">\n                        <tr class=\"bg-[#011F5B] text-white\" data-kid=\"147\">\n                            <th class=\"p-8 font-serif text-2xl font-bold border-r border-white/5\" data-kid=\"148\">Detection Capabilities</th>\n                            <th class=\"p-8 font-sans text-xs uppercase tracking-widest text-white/50 border-r border-white/5 text-center w-1/4\" data-kid=\"149\">Standard Antivirus</th>\n                            <th class=\"p-8 font-sans text-xs uppercase tracking-widest bg-[#E60026] text-white text-center w-1/4\" data-kid=\"150\">SafeLink Fortress</th>\n                        </tr>\n                    </thead>\n                    <tbody class=\"text-[#011F5B]\" data-kid=\"151\">\n                        <tr class=\"border-b border-[#011F5B]/5 group hover:bg-[#F8F8FF] transition-all\" data-kid=\"152\">\n                            <td class=\"p-8 border-r border-[#011F5B]/5\" data-kid=\"153\">\n                                <div class=\"font-bold text-lg\" data-kid=\"154\">Typosquatting Protection</div>\n                                <div class=\"text-sm text-[#011F5B]/50 mt-1\" data-kid=\"155\">Detecting subtle variations in common domain names.</div>\n                            </td>\n                            <td class=\"p-8 border-r border-[#011F5B]/5 text-center text-[#011F5B]/30\" data-kid=\"156\">\n                                <i class=\"ti ti-x text-2xl\" data-kid=\"157\"></i>\n                            </td>\n                            <td class=\"p-8 text-center bg-[#E60026]/5 text-[#E60026]\" data-kid=\"158\">\n                                <i class=\"ti ti-circle-check-filled text-3xl\" data-kid=\"159\"></i>\n                            </td>\n                        </tr>\n                        <tr class=\"border-b border-[#011F5B]/5 group hover:bg-[#F8F8FF] transition-all\" data-kid=\"160\">\n                            <td class=\"p-8 border-r border-[#011F5B]/5\" data-kid=\"161\">\n                                <div class=\"font-bold text-lg\" data-kid=\"162\">Web3 / Crypto Scams</div>\n                                <div class=\"text-sm text-[#011F5B]/50 mt-1\" data-kid=\"163\">Prevention of wallet drainers and phishing mint sites.</div>\n                            </td>\n                            <td class=\"p-8 border-r border-[#011F5B]/5 text-center text-[#011F5B]/30\" data-kid=\"164\">\n                                <i class=\"ti ti-x text-2xl\" data-kid=\"165\"></i>\n                            </td>\n                            <td class=\"p-8 text-center bg-[#E60026]/5 text-[#E60026]\" data-kid=\"166\">\n                                <i class=\"ti ti-circle-check-filled text-3xl\" data-kid=\"167\"></i>\n                            </td>\n                        </tr>\n                        <tr class=\"border-b border-[#011F5B]/5 group hover:bg-[#F8F8FF] transition-all\" data-kid=\"168\">\n                            <td class=\"p-8 border-r border-[#011F5B]/5\" data-kid=\"169\">\n                                <div class=\"font-bold text-lg\" data-kid=\"170\">Malicious PDF Analysis</div>\n                                <div class=\"text-sm text-[#011F5B]/50 mt-1\" data-kid=\"171\">Deep scanning for embedded JS or external calling URLs.</div>\n                            </td>\n                            <td class=\"p-8 border-r border-[#011F5B]/5 text-center\" data-kid=\"172\">\n                                <span class=\"text-[10px] font-black text-orange-500 border border-orange-500 px-2 py-0.5 rounded uppercase\" data-kid=\"173\">Reactive only</span>\n                            </td>\n                            <td class=\"p-8 text-center bg-[#E60026]/5 text-[#E60026]\" data-kid=\"174\">\n                                <i class=\"ti ti-circle-check-filled text-3xl\" data-kid=\"175\"></i>\n                            </td>\n                        </tr>\n                        <tr class=\"border-b border-[#011F5B]/5 group hover:bg-[#F8F8FF] transition-all\" data-kid=\"176\">\n                            <td class=\"p-8 border-r border-[#011F5B]/5\" data-kid=\"177\">\n                                <div class=\"font-bold text-lg\" data-kid=\"178\">AI-Powered Zero Day detection</div>\n                                <div class=\"text-sm text-[#011F5B]/50 mt-1\" data-kid=\"179\">Heuristic modeling for never-before-seen threats.</div>\n                            </td>\n                            <td class=\"p-8 border-r border-[#011F5B]/5 text-center text-[#011F5B]/30\" data-kid=\"180\">\n                                <i class=\"ti ti-x text-2xl\" data-kid=\"181\"></i>\n                            </td>\n                            <td class=\"p-8 text-center bg-[#E60026]/5 text-[#E60026]\" data-kid=\"182\">\n                                <i class=\"ti ti-circle-check-filled text-3xl\" data-kid=\"183\"></i>\n                            </td>\n                        </tr>\n                        <tr class=\"group hover:bg-[#F8F8FF] transition-all\" data-kid=\"184\">\n                            <td class=\"p-8 border-r border-[#011F5B]/5\" data-kid=\"185\">\n                                <div class=\"font-bold text-lg\" data-kid=\"186\">Latency Impact</div>\n                                <div class=\"text-sm text-[#011F5B]/50 mt-1\" data-kid=\"187\">Organizational drag caused by security inspection.</div>\n                            </td>\n                            <td class=\"p-8 border-r border-[#011F5B]/5 text-center\" data-kid=\"188\">\n                                <span class=\"text-[10px] font-black text-[#011F5B]/40 uppercase tracking-tighter\" data-kid=\"189\">&gt; 500ms</span>\n                            </td>\n                            <td class=\"p-8 text-center bg-[#E60026]/5 text-[#E60026]\" data-kid=\"190\">\n                                <span class=\"text-xs font-black uppercase tracking-widest\" data-kid=\"191\">&lt; 1ms</span>\n                            </td>\n                        </tr>\n                    </tbody>\n                </table>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-24 bg-[#F8F8FF] px-8 relative overflow-hidden\" data-kid=\"192\">\n        <div class=\"max-w-4xl mx-auto text-center relative z-10\" data-kid=\"193\">\n            <div class=\"text-[#E60026] mb-6\" data-kid=\"194\">\n                <i class=\"ti ti-quote text-5xl opacity-20\" data-kid=\"195\"></i>\n            </div>\n            <h2 class=\"text-4xl md:text-5xl font-serif text-[#011F5B] leading-[1.3] mb-10\" data-kid=\"196\">\n                \"Implementing SafeLink across our 12,000 endpoints reduced phishing-related incidents by <span class=\"text-[#E60026]\" data-kid=\"197\">94% in the first quarter</span>. It's the only solution we've found that doesn't slow down our engineers.\"\n            </h2>\n            <div class=\"flex flex-col items-center gap-4\" data-kid=\"198\">\n                <div class=\"w-20 h-20 rounded-full overflow-hidden border-4 border-white shadow-xl\" data-kid=\"199\">\n                    <img src=\"https://images.pexels.com/photos/8353835/pexels-photo-8353835.jpeg?auto=compress&cs=tinysrgb&w=200&q=80\" alt=\"CISO Portrait\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"200\">\n                </div>\n                <div data-kid=\"201\">\n                    <div class=\"text-lg font-bold text-[#011F5B]\" data-kid=\"202\">Marcus Thorne</div>\n                    <div class=\"text-sm font-bold text-[#011F5B]/50 uppercase tracking-widest\" data-kid=\"203\">Chief Information Security Officer, Apex Financial</div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-8\" data-kid=\"204\">\n        <div class=\"max-w-6xl mx-auto bg-[#011F5B] rounded-2xl p-16 md:p-24 text-center relative overflow-hidden shadow-2xl\" data-kid=\"205\">\n            \n            <div class=\"absolute -top-24 -left-24 w-64 h-64 bg-[#E60026]/10 rounded-full blur-3xl\" data-kid=\"206\"></div>\n            <div class=\"absolute -bottom-24 -right-24 w-64 h-64 bg-[#F8F8FF]/5 rounded-full blur-3xl\" data-kid=\"207\"></div>\n            \n            <div class=\"relative z-10 max-w-3xl mx-auto\" data-kid=\"208\">\n                <h2 class=\"text-5xl md:text-6xl font-serif text-white mb-8\" data-kid=\"209\">Enterprise-grade security, <br data-kid=\"210\"><span class=\"text-[#E60026]\" data-kid=\"211\">zero latency.</span></h2>\n                <p class=\"text-white/60 text-xl mb-12\" data-kid=\"212\">Deploy SafeLink in minutes and experience the next generation of digital perimeter defense.</p>\n                \n                <div class=\"flex flex-col sm:flex-row items-center justify-center gap-6\" data-kid=\"213\">\n                    <button class=\"w-full sm:w-auto bg-[#E60026] text-white px-10 py-5 text-xl font-bold hover:bg-[#c40020] transition-all shadow-xl shadow-[#E60026]/20\" data-kid=\"214\">\n                        Add to Browser\n                    </button>\n                    <button class=\"w-full sm:w-auto bg-white/10 text-white px-10 py-5 text-xl font-bold hover:bg-white/20 transition-all border border-white/10\" data-kid=\"215\">\n                        Schedule Enterprise Demo\n                    </button>\n                </div>\n                \n                <p class=\"mt-12 text-white/30 text-sm font-semibold tracking-wider uppercase\" data-kid=\"216\">No credit card required • GDPR & SOC2 Compliant</p>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-white border-t border-[#011F5B]/10 py-20 px-8\" data-kid=\"217\">\n        <div class=\"max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-12\" data-kid=\"218\">\n            <div class=\"col-span-2\" data-kid=\"219\">\n                <div class=\"flex items-center gap-2 mb-8\" data-kid=\"220\">\n                    <div class=\"w-8 h-8 bg-[#011F5B] flex items-center justify-center rounded-sm\" data-kid=\"221\">\n                        <i class=\"ti ti-shield-check text-[#F8F8FF] text-xl\" data-kid=\"222\"></i>\n                    </div>\n                    <span class=\"text-xl font-serif font-bold tracking-tight text-[#011F5B]\" data-kid=\"223\">SafeLink</span>\n                </div>\n                <p class=\"text-[#011F5B]/60 max-w-xs leading-relaxed\" data-kid=\"224\">The global standard in real-time link analysis and enterprise anti-scam protection.</p>\n                <div class=\"flex items-center gap-4 mt-8\" data-kid=\"225\">\n                    <a href=\"#\" class=\"w-10 h-10 rounded-full bg-[#011F5B]/5 flex items-center justify-center text-[#011F5B] hover:bg-[#E60026] hover:text-white transition-all\" data-kid=\"226\"><i class=\"ti ti-brand-x\" data-kid=\"227\"></i></a>\n                    <a href=\"#\" class=\"w-10 h-10 rounded-full bg-[#011F5B]/5 flex items-center justify-center text-[#011F5B] hover:bg-[#E60026] hover:text-white transition-all\" data-kid=\"228\"><i class=\"ti ti-brand-linkedin\" data-kid=\"229\"></i></a>\n                    <a href=\"#\" class=\"w-10 h-10 rounded-full bg-[#011F5B]/5 flex items-center justify-center text-[#011F5B] hover:bg-[#E60026] hover:text-white transition-all\" data-kid=\"230\"><i class=\"ti ti-brand-github\" data-kid=\"231\"></i></a>\n                </div>\n            </div>\n            \n            <div data-kid=\"232\">\n                <h4 class=\"font-bold text-[#011F5B] mb-6\" data-kid=\"233\">Product</h4>\n                <ul class=\"space-y-4 text-sm text-[#011F5B]/60 font-semibold\" data-kid=\"234\">\n                    <li data-kid=\"235\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"236\">Link Scanner</a></li>\n                    <li data-kid=\"237\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"238\">Browser Extension</a></li>\n                    <li data-kid=\"239\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"240\">API Access</a></li>\n                    <li data-kid=\"241\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"242\">Integrations</a></li>\n                </ul>\n            </div>\n            \n            <div data-kid=\"243\">\n                <h4 class=\"font-bold text-[#011F5B] mb-6\" data-kid=\"244\">Company</h4>\n                <ul class=\"space-y-4 text-sm text-[#011F5B]/60 font-semibold\" data-kid=\"245\">\n                    <li data-kid=\"246\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"247\">About Us</a></li>\n                    <li data-kid=\"248\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"249\">Security</a></li>\n                    <li data-kid=\"250\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"251\">Contact</a></li>\n                    <li data-kid=\"252\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"253\">Careers</a></li>\n                </ul>\n            </div>\n            \n            <div data-kid=\"254\">\n                <h4 class=\"font-bold text-[#011F5B] mb-6\" data-kid=\"255\">Resources</h4>\n                <ul class=\"space-y-4 text-sm text-[#011F5B]/60 font-semibold\" data-kid=\"256\">\n                    <li data-kid=\"257\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"258\">Blog</a></li>\n                    <li data-kid=\"259\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"260\">Threat Reports</a></li>\n                    <li data-kid=\"261\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"262\">Documentation</a></li>\n                    <li data-kid=\"263\"><a href=\"#\" class=\"hover:text-[#E60026] transition-all\" data-kid=\"264\">Legal</a></li>\n                </ul>\n            </div>\n\n            <div data-kid=\"265\">\n                <h4 class=\"font-bold text-[#011F5B] mb-6\" data-kid=\"266\">Status</h4>\n                <div class=\"inline-flex items-center gap-2.5 px-4 py-1.5 bg-green-50 border border-green-200 rounded-full shadow-sm shadow-green-100\" data-kid=\"267\">\n                    <div class=\"w-2 h-2 bg-green-500 rounded-full animate-pulse\" data-kid=\"268\"></div>\n                    <span class=\"text-[10px] font-black text-green-700 uppercase tracking-[0.1em]\" data-kid=\"269\">Operational</span>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"max-w-7xl mx-auto mt-20 pt-8 border-t border-[#011F5B]/5 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"270\">\n            <p class=\"text-xs text-[#011F5B]/40 font-bold\" data-kid=\"271\">© 2024 SafeLink Cybersecurity Inc. All rights reserved.</p>\n            <div class=\"flex gap-8 text-xs text-[#011F5B]/40 font-bold\" data-kid=\"272\">\n                <a href=\"#\" class=\"hover:text-[#011F5B] transition-all\" data-kid=\"273\">Privacy Policy</a>\n                <a href=\"#\" class=\"hover:text-[#011F5B] transition-all\" data-kid=\"274\">Terms of Service</a>\n                <a href=\"#\" class=\"hover:text-[#011F5B] transition-all\" data-kid=\"275\">Cookie Settings</a>\n            </div>\n        </div>\n    </footer>\n</div>\n",
