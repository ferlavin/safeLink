/div>\n                    \n                    <div class=\"mt-16 pt-16 border-t border-white/5 flex flex-wrap items-center justify-center gap-12 grayscale opacity-40\" data-kid=\"201\">\n                        <span class=\"font-bold text-2xl tracking-tighter\" data-kid=\"202\">FORBES</span>\n                        <span class=\"font-bold text-2xl tracking-tighter\" data-kid=\"203\">TECHCRUNCH</span>\n                        <span class=\"font-bold text-2xl tracking-tighter\" data-kid=\"204\">WIRED</span>\n                        <span class=\"font-bold text-2xl tracking-tighter\" data-kid=\"205\">VERGE</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"py-20 border-t border-white/5\" data-kid=\"206\">\n        <div class=\"container mx-auto px-6\" data-kid=\"207\">\n            <div class=\"flex flex-col md:flex-row justify-between items-center gap-12\" data-kid=\"208\">\n                <div class=\"flex items-center gap-2\" data-kid=\"209\">\n                    <div class=\"w-8 h-8 bg-gradient-to-tr from-[var(--neon-ice)] to-[var(--ocean-twilight)] rounded-lg flex items-center justify-center\" data-kid=\"210\">\n                        <i class=\"ph ph-shield-check-fill text-black text-xl\" data-kid=\"211\"></i>\n                    </div>\n                    <span class=\"text-xl font-extrabold tracking-tight\" data-kid=\"212\">SafeLink</span>\n                </div>\n                \n                <div class=\"flex gap-10 text-white/40 text-sm font-medium\" data-kid=\"213\">\n                    <a href=\"#\" class=\"hover:text-white transition\" data-kid=\"214\">Privacy Policy</a>\n                    <a href=\"#\" class=\"hover:text-white transition\" data-kid=\"215\">Terms of Service</a>\n                    <a href=\"#\" class=\"hover:text-white transition\" data-kid=\"216\">Cookie Policy</a>\n                    <a href=\"#\" class=\"hover:text-white transition\" data-kid=\"217\">Contact Support</a>\n                </div>\n                \n                <div class=\"flex gap-6\" data-kid=\"218\">\n                    <a href=\"#\" class=\"w-10 h-10 glass-panel rounded-full flex items-center justify-center hover:text-[var(--neon-ice)] transition\" data-kid=\"219\">\n                        <i class=\"ph ph-twitter-logo-fill\" data-kid=\"220\"></i>\n                    </a>\n                    <a href=\"#\" class=\"w-10 h-10 glass-panel rounded-full flex items-center justify-center hover:text-[var(--neon-ice)] transition\" data-kid=\"221\">\n                        <i class=\"ph ph-github-logo-fill\" data-kid=\"222\"></i>\n                    </a>\n                    <a href=\"#\" class=\"w-10 h-10 glass-panel rounded-full flex items-center justify-center hover:text-[var(--neon-ice)] transition\" data-kid=\"223\">\n                        <i class=\"ph ph-linkedin-logo-fill\" data-kid=\"224\"></i>\n                    </a>\n                </div>\n            </div>\n            \n            <div class=\"mt-20 text-center text-white/20 text-xs\" data-kid=\"225\">\n                © 2024 SafeLink Technologies Inc. All rights reserved.\n            </div>\n        </div>\n    </footer>\n\n    \n    <script src=\"https://unpkg.com/@phosphor-icons/web\" data-kid=\"226\"></script>\n</body>\n",
