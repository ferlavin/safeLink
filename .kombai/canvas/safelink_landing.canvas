      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Sans:wght@400;500&family=Inconsolata:wght@400;600&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --color-ink-black: #010B13;\n        --color-shadow-grey: #242124;\n        --color-cyan-glow: #0FFFFF;\n        --color-neon-grass: #66FF00;\n    }\n\n    .crosshatch-bg {\n        background-image: \n            linear-gradient(45deg, rgba(15, 255, 255, 0.03) 25%, transparent 25%), \n            linear-gradient(-45deg, rgba(15, 255, 255, 0.03) 25%, transparent 25%), \n            linear-gradient(45deg, transparent 75%, rgba(15, 255, 255, 0.03) 75%), \n            linear-gradient(-45deg, transparent 75%, rgba(15, 255, 255, 0.03) 75%);\n        background-size: 20px 20px;\n    }\n\n    .terminal-shadow {\n        box-shadow: 0 0 50px rgba(0, 0, 0, 0.5), 0 0 20px rgba(15, 255, 255, 0.1);\n    }\n\n    .cyan-text-glow {\n        text-shadow: 0 0 15px rgba(15, 255, 255, 0.5);\n    }\n\n    .green-text-glow {\n        text-shadow: 0 0 15px rgba(102, 255, 0, 0.5);\n    }\n\n    @keyframes glitch {\n        0% { transform: translate(0); }\n        20% { transform: translate(-2px, 2px); }\n        40% { transform: translate(-2px, -2px); }\n        60% { transform: translate(2px, 2px); }\n        80% { transform: translate(2px, -2px); }\n        100% { transform: translate(0); }\n    }\n\n    .glitch-hover:hover {\n        animation: glitch 0.3s cubic-bezier(.25, .46, .45, .94) both infinite;\n    }\n\n    @keyframes marquee {\n        0% { transform: translateX(0); }\n        100% { transform: translateX(-50%); }\n    }\n\n    .animate-marquee {\n        display: flex;\n        width: 200%;\n        animation: marquee 30s linear infinite;\n    }\n\n    .glass-panel {\n        background: rgba(36, 33, 36, 0.7);\n        backdrop-filter: blur(10px);\n        border: 1px solid rgba(255, 255, 255, 0.05);\n    }\n</style>\n\n<div class=\"bg-[#010B13] text-white font-['Fira_Sans'] selection:bg-[#0FFFFF] selection:text-black\" data-kid=\"1\">\n    \n    <nav class=\"relative z-50 flex items-center justify-between px-8 py-6 max-w-7xl mx-auto font-['Space_Grotesk']\" data-kid=\"2\">\n        <div class=\"flex items-center gap-2\" data-kid=\"3\">\n            <div class=\"w-10 h-10 bg-[#0FFFFF] flex items-center justify-center rounded-sm rotate-45\" data-kid=\"4\">\n                <i class=\"ti ti-shield-lock text-black -rotate-45 text-xl font-bold\" data-kid=\"5\"></i>\n            </div>\n            <span class=\"text-2xl font-bold tracking-tighter uppercase italic\" data-kid=\"6\">SafeLink</span>\n        </div>\n        <div class=\"hidden md:flex items-center gap-8 text-sm font-medium text-gray-400\" data-kid=\"7\">\n            <a href=\"#\" class=\"hover:text-[#0FFFFF] transition-colors\" data-kid=\"8\">Core Defenses</a>\n            <a href=\"#\" class=\"hover:text-[#0FFFFF] transition-colors\" data-kid=\"9\">Network Map</a>\n            <a href=\"#\" class=\"hover:text-[#0FFFFF] transition-colors\" data-kid=\"10\">Documentation</a>\n            <div class=\"flex items-center gap-2 bg-[#242124] px-3 py-1 rounded-full border border-gray-800\" data-kid=\"11\">\n                <span class=\"w-1.5 h-1.5 rounded-full bg-[#66FF00] animate-pulse\" data-kid=\"12\"></span>\n                <span class=\"text-[10px] uppercase tracking-widest text-[#66FF00]\" data-kid=\"13\">System Normal</span>\n            </div>\n        </div>\n        <button class=\"bg-transparent border border-[#0FFFFF]/30 text-[#0FFFFF] px-6 py-2 rounded-sm text-sm font-bold uppercase tracking-widest hover:bg-[#0FFFFF] hover:text-black transition-all\" data-kid=\"14\">\n            Get Extension\n        </button>\n    </nav>\n\n    \n    <section class=\"relative pt-12 pb-32 px-6 overflow-hidden crosshatch-bg\" data-kid=\"15\">\n        <div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\" data-kid=\"16\">\n            <div class=\"relative z-10\" data-kid=\"17\">\n                <div class=\"inline-flex items-center gap-2 bg-[#0FFFFF]/10 px-4 py-1.5 rounded-full border border-[#0FFFFF]/20 mb-8\" data-kid=\"18\">\n                    <i class=\"ti ti-bolt text-[#0FFFFF]\" data-kid=\"19\"></i>\n                    <span class=\"text-[#0FFFFF] text-xs font-mono uppercase tracking-[0.2em]\" data-kid=\"20\">Next-Gen Web Defense</span>\n                </div>\n                <h1 class=\"text-6xl lg:text-8xl font-bold font-['Space_Grotesk'] leading-[0.85] tracking-tighter mb-8 italic\" data-kid=\"21\">\n                    SHIELDING <br data-kid=\"22\">\n                    THE <span class=\"text-[#0FFFFF] cyan-text-glow glitch-hover cursor-default\" data-kid=\"23\">VIRTUAL</span> <br data-kid=\"24\">\n                    <span class=\"relative\" data-kid=\"25\">FRONTIER.<span class=\"absolute -bottom-2 left-0 w-1/3 h-1 bg-[#0FFFFF]\" data-kid=\"26\"></span></span>\n                </h1>\n                <p class=\"text-gray-400 text-lg max-w-lg mb-10 leading-relaxed font-light\" data-kid=\"27\">\n                    SafeLink provides autonomous, military-grade protection against phishing, typosquatting, and malicious payloads at the browser level.\n                </p>\n                <div class=\"flex flex-wrap gap-4\" data-kid=\"28\">\n                    <button class=\"bg-[#0FFFFF] text-black font-bold px-10 py-5 rounded-sm hover:shadow-[0_0_30px_rgba(15,255,255,0.4)] transition-all flex items-center gap-3\" data-kid=\"29\">\n                        INSTALL SAFELINK <i class=\"ti ti-arrow-right\" data-kid=\"30\"></i>\n                    </button>\n                    <button class=\"bg-white/5 border border-white/10 text-white font-bold px-10 py-5 rounded-sm hover:bg-white/10 transition-all\" data-kid=\"31\">\n                        VIEW LIVE THREATS\n                    </button>\n                </div>\n            </div>\n\n            \n            <div class=\"relative group\" data-kid=\"32\">\n                <div class=\"absolute -inset-1 bg-gradient-to-r from-[#0FFFFF] to-[#66FF00] rounded-xl blur opacity-10 group-hover:opacity-20 transition duration-1000\" data-kid=\"33\"></div>\n                <div class=\"relative bg-[#242124] rounded-xl border border-white/10 terminal-shadow overflow-hidden\" data-kid=\"34\">\n                    <div class=\"bg-[#1a181a] px-5 py-4 flex items-center justify-between border-b border-white/5\" data-kid=\"35\">\n                        <div class=\"flex gap-2.5\" data-kid=\"36\">\n                            <div class=\"w-3 h-3 rounded-full bg-[#ff5f56]\" data-kid=\"37\"></div>\n                            <div class=\"w-3 h-3 rounded-full bg-[#ffbd2e]\" data-kid=\"38\"></div>\n                            <div class=\"w-3 h-3 rounded-full bg-[#27c93f]\" data-kid=\"39\"></div>\n                        </div>\n                        <div class=\"font-mono text-[10px] text-gray-500 tracking-[0.3em] uppercase\" data-kid=\"40\">SAFELINK_SCANNER_CORE_v4.2.0</div>\n                        <div class=\"w-8\" data-kid=\"41\"></div>\n                    </div>\n                    <div class=\"p-8 font-mono text-sm leading-relaxed min-h-[440px]\" data-kid=\"42\">\n                        <div class=\"text-[#0FFFFF] mb-4\" data-kid=\"43\">$ safelink scan --deep \"https://nexus-vault.web3/connect\"</div>\n                        <div class=\"text-gray-500 mb-2\" data-kid=\"44\">[0.00s] Initializing L4 inspection layer...</div>\n                        <div class=\"text-gray-500 mb-2\" data-kid=\"45\">[0.12s] Performing DNS reputation check...</div>\n                        <div class=\"text-gray-400 mb-2\" data-kid=\"46\">\n                            <span class=\"text-yellow-500\" data-kid=\"47\">[WARN]</span> Potential Typosquatting: \"nexus-vault\" mimics \"nexusvault\"\n                        </div>\n                        <div class=\"text-gray-500 mb-4\" data-kid=\"48\">[0.45s] Extracting Javascript (bundle_v14.js)...</div>\n                        \n                        <div class=\"bg-black/40 p-4 rounded border border-white/5 mb-4 text-xs\" data-kid=\"49\">\n                            <div class=\"mb-1\" data-kid=\"50\"><span class=\"text-gray-600\" data-kid=\"51\">42 |</span> <span class=\"text-cyan-400\" data-kid=\"52\">const</span> <span class=\"text-yellow-300\" data-kid=\"53\">drainer</span> = <span class=\"text-cyan-400\" data-kid=\"54\">async</span> (p) <span class=\"text-pink-400\" data-kid=\"55\">=></span> {</div>\n                            <div class=\"mb-1\" data-kid=\"56\"><span class=\"text-gray-600\" data-kid=\"57\">43 |</span>   <span class=\"text-cyan-400\" data-kid=\"58\">await</span> p.<span class=\"text-yellow-300\" data-kid=\"59\">request</span>({ <span class=\"text-orange-300\" data-kid=\"60\">method</span>: <span class=\"text-green-400\" data-kid=\"61\">\"eth_sendTransaction\"</span>, ... });</div>\n                            <div data-kid=\"62\"><span class=\"text-gray-600\" data-kid=\"63\">44 |</span> <span class=\"text-pink-400\" data-kid=\"64\">}</span>;</div>\n                        </div>\n\n                        <div class=\"text-red-500 font-bold mb-2\" data-kid=\"65\">[CRITICAL] MALICIOUS WALLET DRAINER DETECTED</div>\n                        <div class=\"text-gray-500 mb-6\" data-kid=\"66\">[0.89s] Checking embedded document (whitepaper.pdf)...</div>\n                        <div class=\"text-[#66FF00] mb-8\" data-kid=\"67\">[CLEAN] No malicious macros identified in PDF binary.</div>\n\n                        <div class=\"border-t border-white/5 pt-6\" data-kid=\"68\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"69\">\n                                <div class=\"bg-red-500/20 text-red-500 px-4 py-2 rounded font-bold animate-pulse text-lg border border-red-500/30\" data-kid=\"70\">\n                                    THREAT BLOCKED\n                                </div>\n                                <div class=\"text-gray-500 text-xs italic\" data-kid=\"71\">Request terminated for user safety.</div>\n                            </div>\n                        </div>\n                        \n                        <div class=\"mt-8 flex items-center\" data-kid=\"72\">\n                            <span class=\"text-[#0FFFFF]\" data-kid=\"73\">$</span>\n                            <span class=\"ml-2 w-2.5 h-5 bg-[#0FFFFF] animate-pulse\" data-kid=\"74\"></span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <div class=\"bg-black border-y border-white/5 py-8 overflow-hidden\" data-kid=\"75\">\n        <div class=\"animate-marquee whitespace-nowrap\" data-kid=\"76\">\n            <div class=\"flex items-center gap-24 px-12 opacity-50 grayscale hover:opacity-100 hover:grayscale-0 transition-all cursor-default\" data-kid=\"77\">\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"78\">ETHERNETIC</span>\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"79\">VOID_TECH</span>\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"80\">NEURAL_LINK</span>\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"81\">CYBER_DYNE</span>\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"82\">PROTO_LABS</span>\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"83\">OMNI_NET</span>\n            </div>\n            \n            <div class=\"flex items-center gap-24 px-12 opacity-30 grayscale hover:opacity-100 hover:grayscale-0 transition-all cursor-default\" data-kid=\"84\">\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"85\">ETHERNETIC</span>\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"86\">VOID_TECH</span>\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"87\">NEURAL_LINK</span>\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"88\">CYBER_DYNE</span>\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"89\">PROTO_LABS</span>\n                <span class=\"text-3xl font-['Space_Grotesk'] font-black tracking-tighter uppercase italic\" data-kid=\"90\">OMNI_NET</span>\n            </div>\n        </div>\n    </div>\n\n    \n    <section class=\"pt-24 pb-12 px-6 bg-[#010B13]\" data-kid=\"91\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"92\">\n            <div class=\"flex flex-col md:flex-row items-end justify-between mb-16 gap-8\" data-kid=\"93\">\n                <div data-kid=\"94\">\n                    <h2 class=\"text-5xl font-bold font-['Space_Grotesk'] tracking-tighter mb-4 italic uppercase\" data-kid=\"95\">Autonomous <br data-kid=\"96\"><span class=\"text-[#0FFFFF]\" data-kid=\"97\">Protection</span> Matrix</h2>\n                    <p class=\"text-gray-500 max-w-xl\" data-kid=\"98\">SafeLink operates at the protocol layer, intercepting threats before they execute in your local environment.</p>\n                </div>\n                <div class=\"bg-[#242124] p-6 rounded-lg border border-white/5 flex gap-12\" data-kid=\"99\">\n                    <div data-kid=\"100\">\n                        <div class=\"text-xs text-gray-500 uppercase tracking-widest mb-1\" data-kid=\"101\">Latency</div>\n                        <div class=\"text-[#66FF00] font-mono text-xl\" data-kid=\"102\">0.002ms</div>\n                    </div>\n                    <div data-kid=\"103\">\n                        <div class=\"text-xs text-gray-500 uppercase tracking-widest mb-1\" data-kid=\"104\">Uptime</div>\n                        <div class=\"text-[#66FF00] font-mono text-xl\" data-kid=\"105\">99.999%</div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"grid grid-cols-12 gap-6\" data-kid=\"106\">\n                \n                <div class=\"col-span-12 lg:col-span-8 bg-[#242124] rounded-2xl border border-white/5 p-10 group overflow-hidden relative\" data-kid=\"107\">\n                    <div class=\"absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"108\">\n                        <i class=\"ti ti-code text-[120px]\" data-kid=\"109\"></i>\n                    </div>\n                    <div class=\"relative z-10\" data-kid=\"110\">\n                        <span class=\"text-[#0FFFFF] text-xs font-mono uppercase tracking-[0.3em] mb-6 block\" data-kid=\"111\">Defense Layer 01</span>\n                        <h3 class=\"text-4xl font-bold font-['Space_Grotesk'] mb-6 tracking-tight\" data-kid=\"112\">AI-Driven Script <br data-kid=\"113\">Sanitization</h3>\n                        <p class=\"text-gray-400 max-w-md mb-10\" data-kid=\"114\">Automatically detects and neutralizes obfuscated JavaScript, XSS payloads, and wallet-draining code before injection.</p>\n                        \n                        <div class=\"bg-black/60 rounded-xl border border-white/5 overflow-hidden\" data-kid=\"115\">\n                            <div class=\"bg-[#1a181a] px-4 py-2 border-b border-white/5 flex justify-between items-center\" data-kid=\"116\">\n                                <span class=\"text-[10px] text-gray-500 font-mono\" data-kid=\"117\">JS_INTERCEPTOR</span>\n                                <div class=\"flex gap-1.5\" data-kid=\"118\">\n                                    <div class=\"w-1.5 h-1.5 rounded-full bg-[#0FFFFF]\" data-kid=\"119\"></div>\n                                    <div class=\"w-1.5 h-1.5 rounded-full bg-white/10\" data-kid=\"120\"></div>\n                                </div>\n                            </div>\n                            <div class=\"p-6 font-mono text-xs overflow-x-auto\" data-kid=\"121\">\n                                <div class=\"text-gray-600 mb-2\" data-kid=\"122\">// Captured Payload</div>\n                                <div class=\"text-red-400/70 mb-4 opacity-50 line-through\" data-kid=\"123\">eval(unescape('%77%69%6E%64%6F%77%2E%6C%6F%63%61%74%69%6F%6E...'));</div>\n                                <div class=\"text-gray-600 mb-2\" data-kid=\"124\">// SafeLink Sanitized Output</div>\n                                <div class=\"text-[#66FF00] mb-1\" data-kid=\"125\">/* Blocked: Malicious redirection attempt */</div>\n                                <div class=\"text-[#66FF00]\" data-kid=\"126\">console.log(\"SafeLink: Protection active\");</div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"col-span-12 lg:col-span-4 bg-[#242124] rounded-2xl border border-white/5 p-10 flex flex-col justify-between group hover:border-[#0FFFFF]/30 transition-all duration-500\" data-kid=\"127\">\n                    <div data-kid=\"128\">\n                        <div class=\"w-12 h-12 bg-red-500/10 text-red-500 flex items-center justify-center rounded-lg mb-8 group-hover:scale-110 transition-transform\" data-kid=\"129\">\n                            <i class=\"ti ti-link-off text-2xl\" data-kid=\"130\"></i>\n                        </div>\n                        <h3 class=\"text-2xl font-bold font-['Space_Grotesk'] mb-4 tracking-tight\" data-kid=\"131\">Typosquatting <br data-kid=\"132\">Prevention</h3>\n                        <p class=\"text-gray-400 text-sm leading-relaxed\" data-kid=\"133\">Instantly alerts and redirects you if you land on a deceptive \"look-alike\" domain designed to steal credentials.</p>\n                    </div>\n                    <div class=\"mt-12 bg-black/40 p-5 rounded-lg border border-white/5 relative overflow-hidden\" data-kid=\"134\">\n                        <div class=\"text-[10px] text-gray-600 uppercase tracking-widest mb-3\" data-kid=\"135\">Live Intercept</div>\n                        <div class=\"flex items-center gap-3\" data-kid=\"136\">\n                            <div class=\"text-red-400 font-mono text-sm line-through decoration-2\" data-kid=\"137\">binancee.com</div>\n                            <i class=\"ti ti-arrow-right text-gray-600\" data-kid=\"138\"></i>\n                            <div class=\"text-[#66FF00] font-mono text-sm font-bold\" data-kid=\"139\">binance.com</div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"col-span-12 lg:col-span-4 bg-[#242124] rounded-2xl border border-white/5 p-10 flex flex-col justify-between group h-full\" data-kid=\"140\">\n                    <div data-kid=\"141\">\n                        <div class=\"flex items-center justify-between mb-10\" data-kid=\"142\">\n                            <div class=\"text-[#0FFFFF] text-3xl\" data-kid=\"143\"><i class=\"ti ti-wallet\" data-kid=\"144\"></i></div>\n                            <div class=\"bg-[#66FF00]/10 text-[#66FF00] text-[10px] font-mono border border-[#66FF00]/20 px-2.5 py-1 rounded uppercase tracking-widest\" data-kid=\"145\">Shield On</div>\n                        </div>\n                        <h3 class=\"text-2xl font-bold font-['Space_Grotesk'] mb-4 tracking-tight\" data-kid=\"146\">Web3 Guard</h3>\n                        <p class=\"text-gray-400 text-sm leading-relaxed mb-8\" data-kid=\"147\">Simulation-first transaction engine to prevent wallet-draining signatures and unauthorized approvals.</p>\n                    </div>\n                    <div class=\"flex gap-2\" data-kid=\"148\">\n                        <div class=\"h-1 flex-1 bg-[#66FF00]/20 rounded-full overflow-hidden\" data-kid=\"149\">\n                            <div class=\"h-full bg-[#66FF00] w-3/4 animate-pulse\" data-kid=\"150\"></div>\n                        </div>\n                        <div class=\"h-1 flex-1 bg-[#66FF00]/10 rounded-full\" data-kid=\"151\"></div>\n                    </div>\n                </div>\n\n                \n                <div class=\"col-span-12 lg:col-span-8 bg-[#242124] rounded-2xl border border-white/5 p-10 relative overflow-hidden group\" data-kid=\"152\">\n                    <div class=\"flex items-center gap-12 relative z-10\" data-kid=\"153\">\n                        <div class=\"shrink-0 w-32 h-32 border border-[#0FFFFF]/20 rounded-full flex items-center justify-center group-hover:border-[#0FFFFF]/50 transition-colors\" data-kid=\"154\">\n                            <div class=\"w-24 h-24 border border-[#0FFFFF]/10 rounded-full animate-[spin_10s_linear_infinite] flex items-center justify-center\" data-kid=\"155\">\n                                <div class=\"w-1.5 h-1.5 bg-[#0FFFFF] rounded-full shadow-[0_0_10px_#0FFFFF]\" data-kid=\"156\"></div>\n                            </div>\n                        </div>\n                        <div data-kid=\"157\">\n                            <h3 class=\"text-3xl font-bold font-['Space_Grotesk'] mb-4 tracking-tight\" data-kid=\"158\">Global Node <br data-kid=\"159\">Synchronization</h3>\n                            <p class=\"text-gray-400 max-w-sm mb-6\" data-kid=\"160\">Threat signatures are updated across our global edge network in under 15ms. Stay protected against day-zero exploits.</p>\n                            <div class=\"